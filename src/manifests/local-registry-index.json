{
  "schemaVersion": "1",
  "indexType": "pod-registry-index",
  "name": "daeva-local-sample-index",
  "description": "Local sample registry index for built-in and community pod aliases.",
  "entries": [
    {
      "alias": "whisper",
      "packageName": "daeva-whisper",
      "podId": "whisper",
      "description": "Built-in local Whisper portable package example.",
      "capabilities": ["speech-to-text"],
      "tags": ["builtin", "audio", "transcription"],
      "source": {
        "kind": "local-file",
        "path": "examples/whisper-pod-package",
        "packageManifestPath": "examples/whisper-pod-package/pod-package.json"
      }
    },
    {
      "alias": "comfyapi",
      "packageName": "daeva-comfyapi-pod",
      "podId": "comfyapi",
      "description": "Canonical packaged ComfyUI alias.",
      "capabilities": ["image-generation", "vision"],
      "tags": ["community", "image-generation", "comfyui", "canonical"],
      "source": {
        "kind": "local-file",
        "path": "examples/pod-package-repos/daeva-comfyui-pod",
        "packageManifestPath": "examples/pod-package-repos/daeva-comfyui-pod/pod-package.json"
      }
    },
    {
      "alias": "comfy",
      "packageName": "daeva-comfyapi-pod",
      "podId": "comfyapi",
      "description": "Legacy compatibility alias for the canonical comfyapi package.",
      "capabilities": ["image-generation", "vision"],
      "tags": ["community", "image-generation", "comfyui", "compatibility"],
      "source": {
        "kind": "local-file",
        "path": "examples/pod-package-repos/daeva-comfyui-pod",
        "packageManifestPath": "examples/pod-package-repos/daeva-comfyui-pod/pod-package.json"
      }
    },
    {
      "alias": "vision",
      "packageName": "asmo-ocr-vision-community",
      "podId": "ocr-vision",
      "description": "Alias that resolves through a higher-level community registry index entry.",
      "capabilities": ["ocr", "vision"],
      "tags": ["community", "vision", "ocr"],
      "source": {
        "kind": "registry-index",
        "indexUrl": "https://registry.asmo.local/community/index.json",
        "alias": "ocr-vision"
      }
    }
  ]
}
