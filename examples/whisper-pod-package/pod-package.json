{
  "schemaVersion": "1",
  "packageType": "pod-package",
  "name": "daeva-whisper",
  "version": "0.1.0",
  "description": "Portable package metadata for a local Whisper transcription pod.",
  "pod": {
    "id": "whisper",
    "nickname": "Whisper",
    "description": "Speech-to-text pod for local transcription jobs.",
    "manifestVersion": "1",
    "capabilities": ["speech-to-text"],
    "source": {
      "homepage": "https://github.com/openai/whisper",
      "readme": "https://github.com/openai/whisper#readme",
      "repository": "https://github.com/openai/whisper"
    },
    "runtime": {
      "kind": "http-service",
      "baseUrl": "http://127.0.0.1:8001",
      "healthPath": "/health",
      "submitPath": "/transcribe",
      "method": "POST"
    },
    "install": {
      "command": "${PACKAGE_DIR}/scripts/install.sh"
    },
    "startup": {
      "command": "${PACKAGE_DIR}/scripts/start.sh"
    },
    "shutdown": {
      "command": "${PACKAGE_DIR}/scripts/stop.sh"
    },
    "exclusivityGroup": "gpu-0",
    "metadata": {
      "packageManifestVersion": "1"
    }
  },
  "artifacts": {
    "readme": "README.md",
    "dockerfile": "Dockerfile",
    "installScript": "scripts/install.sh",
    "startScript": "scripts/start.sh",
    "stopScript": "scripts/stop.sh",
    "quadlet": "deploy/whisper.container"
  },
  "directories": [
    {
      "path": "${HOME}/ai/services/whisper/models",
      "purpose": "models",
      "required": true,
      "createIfMissing": true,
      "description": "Whisper model weights. Mounted at /models inside the container."
    },
    {
      "path": "${HOME}/ai/services/whisper/input",
      "purpose": "input",
      "createIfMissing": true,
      "description": "Optional local scratch space for audio uploads."
    }
  ],
  "environment": [
    {
      "name": "WHISPER_MODEL",
      "default": "large-v3-turbo",
      "description": "Whisper model name to load on startup."
    },
    {
      "name": "WHISPER_DEVICE",
      "default": "cuda",
      "description": "Execution device (cuda or cpu).",
      "required": false
    },
    {
      "name": "WHISPER_COMPUTE_TYPE",
      "default": "float16",
      "description": "Quantisation type (float16, int8, etc.).",
      "required": false
    }
  ],
  "install": {
    "strategy": "prebuilt-image",
    "notes": "Pull docker.io/library/daeva-whisper:latest with `podman pull` or use the install script. For quadlet-based installs, copy deploy/whisper.container to ~/.config/containers/systemd/."
  },
  "service": {
    "installMode": "quadlet",
    "serviceName": "daeva-whisper",
    "quadlet": {
      "image": "docker.io/library/daeva-whisper:latest",
      "publishPort": ["8001:8001"],
      "volume": ["${HOME}/ai/services/whisper/models:/models"],
      "environment": [
        "WHISPER_MODEL=large-v3-turbo",
        "WHISPER_COMPUTE_TYPE=float16",
        "WHISPER_DEVICE=cuda"
      ],
      "device": ["nvidia.com/gpu=all"],
      "containerName": "daeva-whisper"
    },
    "systemd": {
      "after": ["network-online.target"],
      "wantedBy": ["default.target"],
      "restart": "on-failure",
      "timeoutStartSec": 120
    }
  },
  "examples": [
    {
      "name": "transcribe-audio",
      "description": "Minimal orchestrator job payload.",
      "request": {
        "type": "transcribe-audio",
        "capability": "speech-to-text",
        "input": {
          "filePath": "/tmp/demo.wav",
          "contentType": "audio/wav"
        }
      }
    }
  ],
  "source": {
    "homepage": "https://github.com/openai/whisper",
    "repository": "https://github.com/example/daeva-whisper-pod-package",
    "documentation": "https://github.com/example/daeva-whisper-pod-package#readme"
  }
}
