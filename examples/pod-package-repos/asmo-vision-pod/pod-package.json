{
  "schemaVersion": "1",
  "packageType": "pod-package",
  "name": "asmo-vision-pod",
  "version": "0.1.0",
  "description": "Portable pod package for local vision/OCR inference via asmo-pod-orchestrator.",
  "pod": {
    "id": "vision",
    "nickname": "Vision",
    "description": "Vision and OCR pod (Ollama + llava or PaddleOCR).",
    "manifestVersion": "1",
    "capabilities": ["vision", "ocr"],
    "source": {
      "homepage": "https://github.com/ollama/ollama",
      "repository": "https://github.com/your-org/asmo-vision-pod"
    },
    "runtime": {
      "kind": "http-service",
      "baseUrl": "http://127.0.0.1:8002",
      "healthPath": "/health",
      "submitPath": "/describe",
      "method": "POST"
    },
    "install": { "command": "${PACKAGE_DIR}/scripts/install.sh" },
    "startup": { "command": "${PACKAGE_DIR}/scripts/start.sh" },
    "shutdown": { "command": "${PACKAGE_DIR}/scripts/stop.sh" }
  },
  "artifacts": {
    "readme": "README.md",
    "installScript": "scripts/install.sh",
    "startScript": "scripts/start.sh",
    "stopScript": "scripts/stop.sh",
    "quadlet": "deploy/vision.container"
  },
  "directories": [
    { "path": "${HOME}/ai/services/vision/models", "purpose": "models", "required": true, "createIfMissing": true },
    { "path": "${HOME}/ai/services/vision/input", "purpose": "input", "createIfMissing": true }
  ],
  "environment": [
    { "name": "VISION_MODEL", "default": "llava" },
    { "name": "VISION_PORT", "default": "8002" }
  ],
  "install": { "strategy": "prebuilt-image" },
  "service": {
    "installMode": "quadlet",
    "serviceName": "asmo-vision",
    "quadlet": {
      "image": "docker.io/library/asmo-vision:latest",
      "publishPort": ["8002:8002"],
      "volume": ["${HOME}/ai/services/vision/models:/models"],
      "device": ["nvidia.com/gpu=all"],
      "containerName": "asmo-vision"
    },
    "systemd": { "after": ["network-online.target"], "wantedBy": ["default.target"], "restart": "on-failure" }
  },
  "source": {
    "repository": "https://github.com/your-org/asmo-vision-pod"
  }
}
